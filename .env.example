# Railway automatically provides DATABASE_URL when you add PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Admin password for the admin panel
ADMIN_PASSWORD=your_strong_password_here

# Telegram bot settings (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Session secret (any random long string)
SESSION_SECRET=your_random_secret_here

# PORT is automatically set by Railway — do NOT set this manually
# NODE_ENV is set by the start command — do NOT set this manually
